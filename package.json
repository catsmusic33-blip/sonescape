{
  "name": "music-desktop-visualizer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:renderer": "vite build --config vite.electron.ts",
    "build:app": "bun run build:renderer && electron-builder --mac"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slider": "^1.4.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@lovable.dev/vite-tanstack-config": "^2.4.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.sonescape.visualizer",
    "productName": "Sonescape",
    "afterPack": "build/afterPack.cjs",
    "files": [
      "main.js",
      "preload.cjs",
      "dist/renderer/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.music",
      "identity": null,
      "target": [
        { "target": "dmg", "arch": ["universal"] },
        { "target": "dir", "arch": ["universal"] }
      ],
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "Sonescape needs screen access to capture system audio for visualization."
      }
    },
    "directories": {
      "output": "release"
    }
  }
}
